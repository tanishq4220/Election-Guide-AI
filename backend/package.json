{
  "name": "backend",
  "version": "1.0.0",
  "description": "Election Guide AI Backend — AI-powered voting assistant API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --forceExit",
    "lint": "eslint ."
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!.eslintrc.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "clover"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.0",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/secret-manager": "^5.0.0",
    "@google/generative-ai": "^0.21.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^6.0.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.5.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  },
  "overrides": {
    "uuid": "^11.0.5",
    "@tootallnate/once": "^3.0.1"
  }
}
